@startuml use_case
left to right direction
title Use Case Diagram — PD Crypto Suite

actor User as U
actor Admin as A

rectangle "PD Crypto Suite" {
  usecase "Регистрация"            as UC1
  usecase "Авторизация"            as UC2
  usecase "Шифр Виженера (enc/dec)"as UC3
  usecase "SHA-384 хеш"            as UC4
  usecase "Метод хорд"             as UC5
  usecase "Стеганография (embed/extract)" as UC6
  usecase "Список пользователей"   as UC7
  usecase "Блокировка пользователя" as UC8
  usecase "Просмотр журнала"       as UC9
}

U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5
U --> UC6

A --|> U : наследует права
A --> UC7
A --> UC8
A --> UC9

UC3 ..> UC2 : <<requires>>
UC4 ..> UC2 : <<requires>>
UC5 ..> UC2 : <<requires>>
UC6 ..> UC2 : <<requires>>
@enduml
